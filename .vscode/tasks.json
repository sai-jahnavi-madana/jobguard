{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Install deps",
      "type": "shell",
      "command": "${workspaceFolder}/backend/venv/Scripts/pip.exe install -r requirements.txt",
      "windows": {
        "command": "${workspaceFolder}\\backend\\venv\\Scripts\\pip.exe install -r requirements.txt"
      },
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build"
    },
    {
      "label": "Backend: Train model",
      "type": "shell",
      "command": "${workspaceFolder}/backend/venv/Scripts/python.exe train_model.py",
      "windows": {
        "command": "${workspaceFolder}\\backend\\venv\\Scripts\\python.exe train_model.py"
      },
      "options": { "cwd": "${workspaceFolder}/backend" },
      "dependsOn": ["Backend: Install deps"]
    },
    {
      "label": "Backend: Run server",
      "type": "shell",
      "command": "${workspaceFolder}/backend/venv/Scripts/uvicorn.exe app.main:app --reload --port 8000",
      "windows": {
        "command": "${workspaceFolder}\\backend\\venv\\Scripts\\uvicorn.exe app.main:app --reload --port 8000"
      },
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "jobguard" }
    },
    {
      "label": "Frontend: Install deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build"
    },
    {
      "label": "Frontend: Run dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "jobguard" },
      "dependsOn": ["Frontend: Install deps"]
    },
    {
      "label": "JobGuard: Run All",
      "dependsOn": ["Backend: Run server", "Frontend: Run dev server"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
